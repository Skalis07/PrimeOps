# FastAPI local settings
APP_ENV=local
APP_NAME=pyme-api
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# PostgreSQL local settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pyme_db
POSTGRES_USER=pyme_user
POSTGRES_PASSWORD=change-me
POSTGRES_CONNECT_TIMEOUT=3

# Optional full override for future SQLAlchemy/Alembic work (A4).
# Leave commented to assemble the URL from POSTGRES_* during local development.
# DATABASE_URL=postgresql+psycopg://pyme_user:change-me@localhost:5432/pyme_db
